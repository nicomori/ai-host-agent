# ─── App ──────────────────────────────────────
APP_PORT=8000
APP_ENV=development

# ─── API Gateway ──────────────────────────────
API_KEY=your-api-key-here

# ─── LLM ─────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Voice ───────────────────────────────────
OPENAI_API_KEY=sk-...                         # Whisper STT (opcional)
ELEVENLABS_API_KEY=sk_...                     # https://elevenlabs.io → Profile → API Key
ELEVENLABS_VOICE_ID=EXAVITQu4vr4xnSDxMaL     # ID de voz (Sarah por defecto)

# ─── Tunnel (Cloudflare Quick Tunnel) ─────────
# La URL es dinámica — se genera al iniciar el container tunnel.
# Para obtenerla: docker compose logs tunnel | grep "trycloudflare.com"
# Luego actualizar TWILIO_WEBHOOK_BASE_URL con esa URL.

# ─── Telephony (Twilio) ───────────────────────
TWILIO_ACCOUNT_SID=AC...                      # https://console.twilio.com
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+1...                     # Número comprado en Twilio
TWILIO_WEBHOOK_BASE_URL=https://xxxx.trycloudflare.com  # URL del tunnel

# ─── PostgreSQL ───────────────────────────────
# Estos valores los usa docker-compose.yml para crear la DB.
# NO cambiar a menos que sepas lo que hacés.
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DB=hostai_db
POSTGRES_USER=hostai_user
POSTGRES_PASSWORD=hostai_pass_2026
DATABASE_URL=postgresql+asyncpg://hostai_user:hostai_pass_2026@localhost:5433/hostai_db

# ─── Redis ────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_URL=redis://localhost:6380/0

# ─── Restaurant ───────────────────────────────
RESTAURANT_NAME="La Trattoria"
RESTAURANT_TIMEZONE=America/Argentina/Buenos_Aires

# ─── LanceDB ───────────────────────────────
LANCEDB_URI=/tmp/hostai_lancedb

# ─── Observability (opcional) ─────────────────
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_BASE_URL=https://cloud.langfuse.com
# LANGSMITH_API_KEY=lsv2_pt_...
