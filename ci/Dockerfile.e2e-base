# HostAI E2E Base — Pre-baked Playwright + Chromium
# Rebuild when e2e/package.json changes or Playwright version bumps.
# Usage: docker build -f ci/Dockerfile.e2e-base -t hostai-e2e-base e2e/

FROM node:20-slim

# System deps for Chromium headless
RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
    fonts-liberation \
    libasound2 \
    libatk-bridge2.0-0 \
    libatk1.0-0 \
    libcups2 \
    libdbus-1-3 \
    libdrm2 \
    libgbm1 \
    libgtk-3-0 \
    libnspr4 \
    libnss3 \
    libxcomposite1 \
    libxdamage1 \
    libxfixes3 \
    libxrandr2 \
    libxss1 \
    xdg-utils \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /e2e

# Install npm deps + Playwright Chromium
COPY package.json package-lock.json* ./
RUN npm ci
RUN npx playwright install chromium

LABEL description="HostAI E2E base image with pre-installed Playwright + Chromium"
